{
  "name": "obsidian-homepage-dashboard",
  "version": "0.1.0",
  "description": "A comprehensive dashboard for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "jest",
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "dashboard",
    "homepage",
    "react"
  ],
  "author": "Kuro Latency",
  "license": "GPL-3.0",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@types/react-grid-layout": "^1.3.6",
    "i18next": "^25.8.11",
    "lodash": "^4.17.23",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-i18next": "^16.5.4",
    "sucrase": "^3.35.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.16.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^5.60.1",
    "@typescript-eslint/parser": "^5.60.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.18.11",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "obsidian": "latest",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6"
  }
}
